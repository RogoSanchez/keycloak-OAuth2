    "version": "0.2.0",
    "configurations": [
        {
            "name": "keycloack_integrations",
            "request": "launch",
            "type": "dart"
        },
        {
            "name": "chrome",
            "request": "launch",
            "type": "dart",
            "args": [
                "-d",
                "chrome",
                "--web-port",
                "3000",
                "--web-browser-flag=--disable-web-security"
            ]
        },
        {
            "name": "keycloack_integrations (profile mode)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "profile"
        },
        {
            "name": "keycloack_integrations (release mode)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "release"
        }
    ]
}